---
import Layout from '../components/Layout.astro';
import MarketingNav from '../components/MarketingNav.astro';
import MarketingSiteFooter from '../components/MarketingSiteFooter.astro';

const title = 'Help';
const description =
  'Guidance, key information, and practical answers for getting the most from Surgical eLogbook.';

const cstPortfolioGuidanceUrl =
  'https://medical.hee.nhs.uk/medical-training-recruitment/medical-specialty-training/surgery/core-surgery/core-surgical-training-portfolio-guidance-for-candidates';
---

<Layout title={title} description={description}>
  <div class="min-h-screen bg-white font-sans text-slate-900">
    <MarketingNav current="help" />

    <div class="relative overflow-hidden bg-gradient-to-br from-clinical-50 via-white to-surface-muted">
      <div class="pointer-events-none absolute -right-24 top-0 h-72 w-72 rounded-full bg-clinical-100/60 blur-3xl"></div>
      <div class="pointer-events-none absolute -left-16 bottom-0 h-64 w-64 rounded-full bg-slate-200/40 blur-3xl"></div>
      <div class="relative mx-auto max-w-6xl px-4 pb-12 pt-10 sm:px-6 sm:pb-16 sm:pt-14">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-clinical-600">Help centre</p>
        <h1 class="mt-2 max-w-2xl text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          Everything you need to know
        </h1>
        <p class="mt-3 max-w-2xl text-lg leading-relaxed text-slate-600">
          Find practical guidance, important information, and clear answers to common questions about using Surgical
          eLogbook.
        </p>
      </div>
    </div>

    <div class="mx-auto max-w-6xl px-4 pb-16 pt-10 sm:px-6 sm:pt-12">
      <div class="lg:grid lg:grid-cols-[minmax(0,14rem)_minmax(0,1fr)] lg:gap-12 xl:gap-16">
        <aside class="mb-10 hidden lg:block">
          <nav class="sticky top-24 space-y-1 text-sm" aria-label="On this page">
            <p class="mb-2 text-[10px] font-bold uppercase tracking-wider text-slate-400">On this page</p>
            <a href="#portfolio-guidance" class="block rounded-lg px-3 py-2 font-medium text-slate-700 hover:bg-slate-100">
              Portfolio guidance
            </a>
            <a href="#faq" class="block rounded-lg px-3 py-2 font-medium text-slate-700 hover:bg-slate-100">FAQ</a>
            <a
              href="#privacy-and-terms"
              class="block rounded-lg px-3 py-2 font-medium text-slate-700 hover:bg-slate-100"
            >
              Privacy and terms
            </a>
            <a href="#contact" class="block rounded-lg px-3 py-2 font-medium text-slate-700 hover:bg-slate-100">Contact</a>
          </nav>
        </aside>

        <div class="min-w-0 space-y-16">
          <section id="portfolio-guidance" class="scroll-mt-28 rounded-2xl border border-slate-200/90 bg-white p-6 shadow-card sm:p-8">
            <h2 class="text-2xl font-bold tracking-tight text-slate-900">Core Surgical Training Portfolio</h2>
            <p class="mt-2 text-sm font-medium text-slate-600">Last updated: 9 May 2026</p>

            <div class="mt-6 max-w-3xl space-y-8">
              <p class="text-sm leading-relaxed text-slate-700">
                NHS England publishes guidance on logging operative cases for Core Surgical Training. The total number of
                procedures you were involved in falls into published bands. Each band corresponds to an indicator; the portfolio
                scoring tables for your recruitment year turn that indicator into marks.
              </p>

              <div class="space-y-3">
                <div class="overflow-x-auto rounded-xl border border-slate-200 shadow-sm">
                  <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                    <thead class="bg-slate-50">
                      <tr>
                        <th
                          scope="col"
                          class="whitespace-nowrap px-4 py-3 text-xs font-bold uppercase tracking-wide text-slate-600"
                        >
                          Procedures involved in
                        </th>
                        <th scope="col" class="px-4 py-3 text-xs font-bold uppercase tracking-wide text-slate-600">Indicator</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 bg-white">
                      <tr>
                        <td class="px-4 py-3 text-slate-800">40 or more cases</td>
                        <td class="px-4 py-3 font-semibold text-slate-900">A</td>
                      </tr>
                      <tr>
                        <td class="px-4 py-3 text-slate-800">30–39 cases</td>
                        <td class="px-4 py-3 font-semibold text-slate-900">B</td>
                      </tr>
                      <tr>
                        <td class="px-4 py-3 text-slate-800">20–29 cases</td>
                        <td class="px-4 py-3 font-semibold text-slate-900">C</td>
                      </tr>
                      <tr>
                        <td class="px-4 py-3 text-slate-800">11–19 cases</td>
                        <td class="px-4 py-3 font-semibold text-slate-900">D</td>
                      </tr>
                      <tr>
                        <td class="px-4 py-3 text-slate-800">10 or fewer / no evidence</td>
                        <td class="px-4 py-3 font-semibold text-slate-900">E</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
                <p class="text-xs leading-relaxed text-slate-500">
                  Involvement includes procedures you assisted or were supervised on. Merely observing procedures does not count
                  towards this number.
                </p>
              </div>

              <div class="space-y-3">
                <p class="text-sm leading-relaxed text-slate-700">
                  Evidence is a verified consolidation report combining all specialties. The report must show the summary sheet
                  showing the number of procedures and date range, and have every page signed by a consultant with their full
                  name, GMC number, and signature date. Recent CST guidance has included the following specialties that count
                  toward surgical portfolio evidence:
                </p>
                <ul class="grid gap-2 rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-800 shadow-sm sm:grid-cols-2">
                  <li class="flex gap-2">
                    <span class="text-clinical-600">•</span>
                    <span>Plastic surgery</span>
                  </li>
                  <li class="flex gap-2">
                    <span class="text-clinical-600">•</span>
                    <span>Neurosurgery</span>
                  </li>
                  <li class="flex gap-2">
                    <span class="text-clinical-600">•</span>
                    <span>Vascular surgery</span>
                  </li>
                  <li class="flex gap-2">
                    <span class="text-clinical-600">•</span>
                    <span>ENT surgery</span>
                  </li>
                  <li class="flex gap-2">
                    <span class="text-clinical-600">•</span>
                    <span>Cardiac / thoracic surgery</span>
                  </li>
                  <li class="flex gap-2">
                    <span class="text-clinical-600">•</span>
                    <span>Urology</span>
                  </li>
                  <li class="flex gap-2">
                    <span class="text-clinical-600">•</span>
                    <span>Oral &amp; maxillofacial surgery</span>
                  </li>
                  <li class="flex gap-2">
                    <span class="text-clinical-600">•</span>
                    <span>General surgery</span>
                  </li>
                  <li class="flex gap-2">
                    <span class="text-clinical-600">•</span>
                    <span>Orthopaedic surgery</span>
                  </li>
                  <li class="flex gap-2">
                    <span class="text-clinical-600">•</span>
                    <span>Paediatric surgery</span>
                  </li>
                </ul>
                <p class="text-xs leading-relaxed text-slate-500">
                  <strong>ITU</strong> appeared on older lists as surgical evidence but from <strong>2025/26</strong> national
                  guidance states ITU is <strong>no longer</strong> considered a surgical specialty{' '}
                  <strong>for portfolio scoring</strong>.
                </p>
              </div>

              <p class="text-sm leading-relaxed text-slate-700">
                No uploaded evidence may identify patients (including hospital numbers, identifiable correspondence). PID usually
                yields zero for that evidence and may be escalated.
              </p>

              <p class="text-sm leading-relaxed text-slate-700">
                Official source:{' '}
                <a
                  href={cstPortfolioGuidanceUrl}
                  class="text-clinical-700 underline decoration-clinical-700/25 underline-offset-2 hover:text-clinical-800 hover:decoration-clinical-800"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Core Surgical Training portfolio guidance for candidates
                </a>
              </p>

              <div class="rounded-xl border border-clinical-200/90 bg-gradient-to-br from-clinical-50/90 via-white to-clinical-50/40 px-4 py-4 text-sm leading-relaxed text-slate-800 shadow-sm">
                <p>
                  Luckily for you, you don't need to worry about any of that: <strong>Surgical eLogbook</strong> complies with
                  everything and handles everything. You only need your consolidation report signed by a consultant—and you're
                  ready to go.
                </p>
              </div>
            </div>
          </section>

          <section id="faq" class="scroll-mt-28">
            <h2 class="text-xl font-bold text-slate-900">Common questions</h2>
            <p class="mt-2 text-sm text-slate-600">Quick answers about using Surgical eLogbook.</p>
            <dl class="mt-6 space-y-3">
              <details class="group rounded-xl border border-slate-200 bg-white shadow-sm open:bg-slate-50/80">
                <summary class="cursor-pointer list-none px-4 py-3 font-semibold text-slate-900 marker:hidden [&::-webkit-details-marker]:hidden">
                  <span class="flex items-center justify-between gap-2">
                    Where is my data stored?
                    <span class="text-slate-400 transition group-open:rotate-180">▼</span>
                  </span>
                </summary>
                <div class="border-t border-slate-100 px-4 py-3 text-sm leading-relaxed text-slate-700">
                  Case rows and your profile live in the database used by your deployment (for example Supabase). PDFs you
                  generate stay on your device unless you choose to share them yourself.
                </div>
              </details>
              <details class="group rounded-xl border border-slate-200 bg-white shadow-sm open:bg-slate-50/80">
                <summary class="cursor-pointer list-none px-4 py-3 font-semibold text-slate-900 marker:hidden [&::-webkit-details-marker]:hidden">
                  <span class="flex items-center justify-between gap-2">
                    Can I use notes for reflective practice?
                    <span class="text-slate-400 transition group-open:rotate-180">▼</span>
                  </span>
                </summary>
                <div class="border-t border-slate-100 px-4 py-3 text-sm leading-relaxed text-slate-700">
                  Yes. Reflective notes are fine as long as they contain <strong>no patient identifiable information</strong>.
                </div>
              </details>
              <details class="group rounded-xl border border-slate-200 bg-white shadow-sm open:bg-slate-50/80">
                <summary class="cursor-pointer list-none px-4 py-3 font-semibold text-slate-900 marker:hidden [&::-webkit-details-marker]:hidden">
                  <span class="flex items-center justify-between gap-2">
                    Is this approved by the GMC or my deanery?
                    <span class="text-slate-400 transition group-open:rotate-180">▼</span>
                  </span>
                </summary>
                <div class="border-t border-slate-100 px-4 py-3 text-sm leading-relaxed text-slate-700">
                  The app is a tool to help you keep a structured log. Formal approval for portfolio or ARCP submission is
                  between you and your local educators. Always follow their guidance.
                </div>
              </details>
            </dl>
          </section>

          <section id="privacy-and-terms" class="scroll-mt-28 rounded-2xl border border-slate-200/90 bg-white p-6 shadow-card sm:p-8">
            <h2 class="text-2xl font-bold tracking-tight text-slate-900">Privacy and terms</h2>

            <div class="mt-6 max-w-3xl space-y-6">
              <h3 id="privacy-policy" class="scroll-mt-28 text-lg font-bold text-slate-900">Privacy policy</h3>
              <p class="text-sm leading-relaxed text-slate-700">
                Surgical eLogbook stores your account email, grade, preferences (for example name title, full name, GMC number,
                default trust, specialty, tags, and form defaults), saved consultants (firstname, surname, GMC for reuse on
                forms), and each case entry you save (date, specialty, trust or hospital name from the official list,
                procedure tags, CEPOD category, consultant details, your role, and optional notes).
              </p>
              <p class="text-sm leading-relaxed text-slate-700">
                You must not enter patient identifiable information anywhere in the app, including in notes. That means no
                patient names, NHS numbers, hospital numbers, dates of birth, addresses, phone numbers, or anything else that
                could identify an individual patient.
              </p>
              <p class="text-sm leading-relaxed text-slate-700">
                Training PDFs are generated in your browser on your device. They are not uploaded to or stored on our servers
                as part of that process.
              </p>
              <p class="text-sm leading-relaxed text-slate-700">
                This product does not include third party advertising or analytics scripts by default. If your deployment adds
                analytics, that should be disclosed separately by whoever operates the instance.
              </p>
              <p class="text-sm leading-relaxed text-slate-700">
                From the app you can export your cases (for example CSV or JSON, depending on what the app offers) and delete
                your account. Account deletion is intended to remove your profile and logbook data from the application
                database; removing the underlying authentication account may depend on your operator’s configuration (see
                deployment documentation).
              </p>
              <h3 id="terms-of-use" class="scroll-mt-28 pt-4 text-lg font-bold text-slate-900">Terms of use</h3>
              <p class="text-sm leading-relaxed text-slate-700">
                Surgical eLogbook is an educational and training logbook. It is not an official medical record, legal record of
                care, or a mandated clinical system. Your deanery, employer, trust, or regulator may require additional
                evidence, signatures, or approved systems.
              </p>
              <p class="text-sm leading-relaxed text-slate-700">
                You are responsible for the accuracy and lawfulness of what you enter. You must not enter patient identifiable
                information. Do not rely on this app as the sole record where another system is required by policy or law.
              </p>
              <p class="text-sm leading-relaxed text-slate-700">
                The software is provided as is, without warranties of any kind to the extent permitted by law. To the extent
                permitted by law, operators and contributors are not liable for loss arising from use or inability to use the
                service.
              </p>
              <p class="text-sm leading-relaxed text-slate-700">
                We may update these terms or the privacy policy from time to time. Continued use of the app after changes are
                posted constitutes acceptance of the updated documents where applicable law allows.
              </p>
            </div>

            <div class="mt-10 max-w-3xl border-t border-slate-200 pt-6">
              <p class="text-sm text-slate-500">
                Last updated:{' '}
                {new Date().toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
            </div>
          </section>

          <div id="contact" class="scroll-mt-28 rounded-2xl bg-gradient-to-br from-clinical-600 to-clinical-800 px-6 py-10 text-center text-white shadow-card sm:px-10">
            <p class="text-sm font-semibold uppercase tracking-wider text-white/80">Still unsure?</p>
            <p class="mt-2 text-lg font-bold">We’re happy to hear from trainees and trainers.</p>
            <a
              href="mailto:surgicalelogbook@proton.me"
              class="mt-6 inline-flex rounded-xl bg-white px-6 py-3 text-sm font-bold text-clinical-800 shadow-sm transition hover:bg-clinical-50"
            >
              surgicalelogbook@proton.me
            </a>
          </div>
        </div>
      </div>
    </div>

    <MarketingSiteFooter hideSecondaryNav={true} />
  </div>
</Layout>
